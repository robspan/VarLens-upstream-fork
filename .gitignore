!resources/gene_reference.db

# Temporary files
tmp/
temp/
*.tmp

# Vendor assets copied from node_modules at build time (see npm run copy:molstar)
src/renderer/public/pdbe-molstar-component.js
src/renderer/public/pdbe-molstar-light.css

# AppImage extraction artifacts
squashfs-root/

# Coverage
coverage/

# TypeScript build info
*.tsbuildinfo

# Sensitive genetic/clinical data - never commit
test-data/
plan/
*.json.gz

# VitePress
.vitepress/
docs/.vitepress/dist
docs/.vitepress/cache

# Auto-generated documentation screenshots (regenerated by Playwright)
docs/public/screenshots/*.png

# Worktrees
.worktrees/

# Preventive: common genomic formats
*.vcf
*.vcf.gz
*.bam
*.sam
*.cram
*.bed
*.fastq

# Exception: small VCF test fixtures for VCF import/trio testing
!tests/test-data/
!tests/test-data/vcf/
!tests/test-data/vcf/**
*.fq
*.fastq.gz
*.fq.gz
*.ped
e2e-dsl-test.mjs
e2e-screenshots/
*.png
e2e-screenshots/
