# Caddy-Konfiguration Konzept-Pilot (Intranet, Self-Signed).
#
# Konzept-Stand: Single-Server, kein DNS-Eintrag, kein Public-CA-Zertifikat.
# Caddy stellt mit `tls internal` ein selbst-signiertes Zertifikat aus seiner
# internen CA aus. Browser zeigen beim Erstaufruf eine Warnung — im Intranet
# akzeptabel und durch §vertrag5 (Echt-Daten-Sperre, Konzept = Test-Daten)
# gedeckt. Stufe 2 ersetzt `tls internal` durch eine Domain → Caddy holt dann
# automatisch ein Let's-Encrypt-Zertifikat (siehe Beispiel am Dateiende).

{
	# Caddy würde sonst versuchen, automatisch HTTPS für jeden Site-Block zu
	# aktivieren, inklusive ACME-Versuchen. Wir machen das hier explizit.
	auto_https disable_redirects
	# Wenn ein Client ohne SNI auf :443 verbindet (curl gegen IP, älterer
	# Browser), liefern wir das für SERVER_HOST ausgestellte Zertifikat.
	default_sni {$SERVER_HOST}
}

# Port 80: HTTP-Anfragen auf HTTPS umleiten, damit niemand versehentlich
# unverschlüsselt landet. 308 statt 301, weil POST-Bodies erhalten bleiben.
:80 {
	redir https://{host}{uri} 308
}

# Port 443: TLS mit Caddy-internem Self-Signed-Zertifikat. SERVER_HOST kommt
# aus compose/.env (= Server-IPv4 oder Hostname). Caddy stellt einen Cert für
# diesen Namen aus seiner internen CA aus.
{$SERVER_HOST}:443 {
	tls internal

	# Welcome-Page auf Wurzel-Pfad.
	@root path /
	handle @root {
		respond "VarLens Konzept-Pilot - läuft.

Monitoring (Basic-Auth, Login admin / varlens-konzept):
- Uptime Kuma:   /monitor/
- Dozzle Logs:   /logs/

Hinweis: Self-Signed-Zertifikat aus Caddy-interner CA (Konzept-Pilot Intranet).
Stand April 2026: Anwendungs-Container und Datenbank kommen noch.
" 200
	}

	# Uptime Kuma unter /monitor/
	handle_path /monitor/* {
		basic_auth {
			# Hash erzeugen mit:
			#   docker exec caddy caddy hash-password
			# Default-Login: admin / varlens-konzept
			admin $2a$14$6QBIGJyJFZMJIomvheSxvOUokBVZsvz03snLpmL7auY8aBmxVfNKy
		}
		reverse_proxy uptime-kuma:3001
	}

	# Dozzle unter /logs/
	handle_path /logs/* {
		basic_auth {
			# Default-Login: admin / varlens-konzept
			admin $2a$14$6QBIGJyJFZMJIomvheSxvOUokBVZsvz03snLpmL7auY8aBmxVfNKy
		}
		reverse_proxy dozzle:8080
	}

	# Alles andere: 404
	handle {
		respond "Not Found" 404
	}
}

# --- Stufe 2: Public-Domain mit Let's-Encrypt --------------------------------
# Sobald eine Domain auf den Server zeigt, den :443-Block oben durch folgende
# Site-Blöcke ersetzen. Caddy holt automatisch ein gültiges Zertifikat per
# ACME (HTTP-01 oder TLS-ALPN-01) und erneuert es selbständig.
#
# varlens.example.de {
# 	reverse_proxy app:3000
# }
# monitor.varlens.example.de {
# 	basic_auth { admin $2a$14$... }
# 	reverse_proxy uptime-kuma:3001
# }
# logs.varlens.example.de {
# 	basic_auth { admin $2a$14$... }
# 	reverse_proxy dozzle:8080
# }
