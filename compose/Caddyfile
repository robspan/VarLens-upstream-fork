# Caddy configuration for the Concept Pilot (intranet, self-signed).
#
# Concept Pilot state: single server, no DNS record, no public CA certificate.
# With `tls internal`, Caddy issues a self-signed certificate from its
# internal CA. Browsers show a warning on first access - acceptable on the
# intranet and covered by §vertrag5 (no real data, Concept = test data).
# Stage 2 replaces `tls internal` with a domain so Caddy automatically
# obtains a Let's Encrypt certificate (see example at the end of the file).

{
	# Without this, Caddy would try to enable HTTPS automatically for every
	# site block, including ACME attempts. We do this explicitly here.
	auto_https disable_redirects
	# If a client connects to :443 without SNI (curl against an IP, an older
	# browser), serve the certificate issued for SERVER_HOST.
	default_sni {$SERVER_HOST}
}

# Port 80: redirect HTTP requests to HTTPS so nobody accidentally lands on
# an unencrypted connection. 308 instead of 301 to preserve POST bodies.
:80 {
	redir https://{host}{uri} 308
}

# Port 443: TLS with Caddy's internal self-signed certificate. SERVER_HOST
# comes from compose/.env (= server IPv4 or hostname). Caddy issues a cert
# for this name from its internal CA.
{$SERVER_HOST}:443 {
	tls internal

	# Welcome page on the root path.
	@root path /
	handle @root {
		respond "VarLens Concept Pilot - running.

Monitoring (basic auth, login admin / varlens-konzept):
- Uptime Kuma:   /monitor/
- Dozzle Logs:   /logs/

Note: self-signed certificate from Caddy's internal CA (Concept Pilot intranet).
As of April 2026: application container and database are still to come.
" 200
	}

	# Uptime Kuma at /monitor/
	handle_path /monitor/* {
		basic_auth {
			# Generate a hash with:
			#   docker exec caddy caddy hash-password
			# Default login: admin / varlens-konzept
			admin $2a$14$6QBIGJyJFZMJIomvheSxvOUokBVZsvz03snLpmL7auY8aBmxVfNKy
		}
		reverse_proxy uptime-kuma:3001
	}

	# Dozzle at /logs/. Dozzle is base-aware (DOZZLE_BASE=/logs in compose)
	# and emits asset URLs under /logs/... - therefore `handle` (no strip).
	handle /logs* {
		basic_auth {
			# Default login: admin / varlens-konzept
			admin $2a$14$6QBIGJyJFZMJIomvheSxvOUokBVZsvz03snLpmL7auY8aBmxVfNKy
		}
		reverse_proxy dozzle:8080
	}

	# Everything else: 404
	handle {
		respond "Not Found" 404
	}
}

# --- Stage 2: public domain with Let's Encrypt -------------------------------
# As soon as a domain points to the server, replace the :443 block above with
# the following site blocks. Caddy will automatically obtain a valid
# certificate via ACME (HTTP-01 or TLS-ALPN-01) and renew it on its own.
#
# varlens.example.de {
# 	reverse_proxy app:3000
# }
# monitor.varlens.example.de {
# 	basic_auth { admin $2a$14$... }
# 	reverse_proxy uptime-kuma:3001
# }
# logs.varlens.example.de {
# 	basic_auth { admin $2a$14$... }
# 	reverse_proxy dozzle:8080
# }
