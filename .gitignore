# Dependencies
node_modules/

# Build output
dist/
out/
release/

# Tool caches
.eslintcache
.prettiercache
.cache/

# Playwright
.playwright-mcp/
playwright-report/
playwright-output/
test-results/

# IDE
.idea/
.vscode/*
!.vscode/settings.json
.codex
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Environment
.env
.env.local
.env.*.local

# Database
*.db
*.db-journal
# Exception: gene reference DB ships with the app
!resources/gene_reference.db

# Temporary files
tmp/
temp/
*.tmp

# Local performance artifacts
# (Use /* glob rather than /-suffix so we can re-include specific files
# below — git refuses file-level exceptions inside an ignored directory.)
.planning/artifacts/perf/*
!.planning/artifacts/perf/phase1/
.planning/artifacts/perf/phase1/*
!.planning/artifacts/perf/phase1/.gitkeep
!.planning/artifacts/perf/wgs-import/
.planning/artifacts/perf/wgs-import/*
!.planning/artifacts/perf/wgs-import/.gitkeep
# Exception: the postgres-blocker doc is the one perf artifact we commit
# because it documents a phase-blocking failure + its resolution.
!.planning/artifacts/perf/wgs-import/2026-04-25-postgres-blocker.md

# Vendor assets copied from node_modules at build time (see npm run copy:molstar)
src/renderer/public/pdbe-molstar-component.js
src/renderer/public/pdbe-molstar-light.css

# AppImage extraction artifacts
squashfs-root/

# Coverage
coverage/

# TypeScript build info
*.tsbuildinfo

# Sensitive genetic/clinical data - never commit
test-data/
plan/
*.json.gz

# WGS perf benchmark fixtures (artifact outputs handled in the
# "Local performance artifacts" block above).
tests/.cache/wgs/

# VitePress — build artifacts only; `docs/.vitepress/config.mts` is tracked
docs/.vitepress/dist/
docs/.vitepress/cache/

# Documentation screenshots under `docs/public/screenshots/` are tracked so
# they ship with the published docs. They can still be regenerated locally
# via the per-feature Playwright scripts (e.g. tests/e2e/shortlist-docs-screenshots.e2e.ts).

# Worktrees
.worktrees/

# Preventive: common genomic formats
*.vcf
*.vcf.gz
*.bam
*.sam
*.cram
*.bed
*.fastq

# Exception: small VCF test fixtures for VCF import/trio testing
!tests/test-data/
!tests/test-data/vcf/
!tests/test-data/vcf/**
*.fq
*.fastq.gz
*.fq.gz
*.ped
!tests/test-data/vcf/*.ped
e2e-dsl-test.mjs
e2e-screenshots/
*.png
# Exception: documentation screenshots are tracked so the published docs site
# can render them without requiring a local Playwright run + ONT fixture.
!docs/public/screenshots/*.png
