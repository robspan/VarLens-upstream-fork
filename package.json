{
  "name": "varlens",
  "version": "0.68.0",
  "description": "Offline variant analysis tool for external collaborators",
  "main": "./out/main/index.js",
  "homepage": "https://github.com/berntpopp/VarLens",
  "author": "Bernt Popp <bernt.popp@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=24.15.0 <25",
    "npm": ">=11.11.0 <12"
  },
  "packageManager": "npm@11.11.0",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:electron": "electron-vite build",
    "build:web": "vite build --config vite.web.config.ts && vite build --config vite.web-renderer.config.ts",
    "build:web:server": "vite build --config vite.web.config.ts",
    "build:web:renderer": "vite build --config vite.web-renderer.config.ts",
    "dev:web:renderer": "vite --config vite.web-renderer.config.ts",
    "preview": "electron-vite preview",
    "dist": "electron-vite build && electron-builder --publish onTag",
    "dist:win": "electron-vite build && electron-builder --win --publish onTag",
    "dist:mac": "electron-vite build && electron-builder --mac --publish onTag",
    "dist:linux": "electron-vite build && electron-builder --linux --publish onTag",
    "postinstall": "npx @electron/rebuild -f -w better-sqlite3-multiple-ciphers",
    "rebuild:electron": "npx @electron/rebuild -f -w better-sqlite3-multiple-ciphers",
    "rebuild:node": "npm rebuild better-sqlite3-multiple-ciphers",
    "lint": "eslint . --cache --cache-strategy content --concurrency=auto --fix",
    "lint:check": "eslint . --cache --cache-strategy content --concurrency=auto",
    "agent:check": "node scripts/check-agent-health.mjs",
    "format": "prettier --cache --write .",
    "format:check": "prettier --cache --check .",
    "test": "vitest run --project main --project renderer",
    "test:watch": "vitest --project main --project renderer",
    "test:coverage": "COVERAGE=1 vitest run --project main --project renderer --coverage",
    "test:web-gate": "vitest run --project web-gate",
    "test:web-smoke": "node tests/web-smoke/run-web-smoke.cjs run",
    "test:web-smoke:open": "node tests/web-smoke/run-web-smoke.cjs open",
    "test:ipc-parity-fixtures": "npx tsx scripts/ipc-parity/validate-fixtures.ts",
    "typecheck": "run-p -l -c typecheck:renderer typecheck:node",
    "typecheck:renderer": "vue-tsc --noEmit -p tsconfig.renderer.json",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "icons:generate": "png2icons resources/icon@2x.png build/icon -icns -ico && cp build/icon.ico resources/icon.ico",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:screenshots": "npx playwright test tests/e2e/screenshots.e2e.ts",
    "build:gene-ref": "npx tsx scripts/build-gene-reference-db.ts",
    "varlens:hash-password": "npx tsx scripts/varlens-hash-password.ts"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@electron/fuses": "^2.1.2",
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^10.0.1",
    "@mdi/js": "^7.4.47",
    "@playwright/test": "^1.60.0",
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/d3": "^7.4.3",
    "@types/file-saver": "^2.0.7",
    "@types/markdown-it": "^14.1.2",
    "@types/nock": "^11.1.0",
    "@types/node": "^25.9.2",
    "@types/pg": "^8.20.0",
    "@types/plotly.js": "^3.0.10",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/test-utils": "^2.4.11",
    "electron": "^40.10.2",
    "electron-builder": "^26.15.2",
    "electron-vite": "^5.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "fast-check": "^4.8.0",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.2",
    "nock": "^14.0.15",
    "npm-run-all2": "^9.0.1",
    "playwright": "^1.59.1",
    "png2icons": "^2.0.1",
    "prettier": "^3.8.2",
    "sass-embedded": "^1.100.0",
    "tar": "^7.5.16",
    "ts-morph": "^28.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^7.3.3",
    "vite-plugin-vuetify": "^2.1.3",
    "vitepress": "^2.0.0-alpha.17",
    "vitest": "^4.0.18",
    "vue": "^3.5.38",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.4"
  },
  "build": {
    "appId": "com.varlens.app",
    "productName": "Varlens",
    "icon": "build/icon.png",
    "npmRebuild": false,
    "afterPack": "scripts/configure-fuses.mjs",
    "extraResources": [
      {
        "from": "resources/gene_reference.db",
        "to": "gene_reference.db"
      },
      {
        "from": "src/main/storage/postgres/migrations/sql",
        "to": "postgres-migrations"
      }
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3-multiple-ciphers/**/*"
    ],
    "files": [
      "out/**/*",
      "node_modules/better-sqlite3-multiple-ciphers/**/*"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "berntpopp",
      "repo": "varlens",
      "releaseType": "draft"
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable",
        "zip"
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.exe"
    },
    "linux": {
      "icon": "build/icons",
      "target": [
        "AppImage",
        "deb"
      ],
      "artifactName": "${productName}-${version}.${ext}",
      "category": "Science"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/secure-session": "^8.2.0",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@node-rs/argon2": "^2.0.2",
    "@vueuse/core": "^14.3.0",
    "adm-zip": "^0.5.17",
    "better-sqlite3-multiple-ciphers": "^12.10.0",
    "bottleneck": "^2.19.5",
    "d3": "^7.9.0",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "fastify": "^5.8.5",
    "fastify-type-provider-zod": "^6.1.0",
    "file-saver": "^2.0.5",
    "jstat": "^1.9.6",
    "kysely": "^0.29.2",
    "markdown-it": "^14.2.0",
    "nanoid": "^5.1.11",
    "pdbe-molstar": "^3.12.0",
    "pg": "^8.21.0",
    "pg-copy-streams": "^7.0.0",
    "pg-query-stream": "^4.15.0",
    "pinia": "^3.0.4",
    "piscina": "^5.1.4",
    "plotly.js-basic-dist-min": "^3.6.0",
    "stream-json": "^3.4.0",
    "vue-router": "^5.1.0",
    "vuedraggable": "^4.1.0",
    "vuetify": "^4.1.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.4.3"
  },
  "overrides": {
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "@xmldom/xmldom": "^0.8.13",
    "lodash": "^4.18.1"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "none",
    "printWidth": 100,
    "endOfLine": "lf"
  }
}
