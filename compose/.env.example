# Environment-Werte für den Compose-Stack.
# Wird von Docker Compose automatisch geladen wenn als compose/.env vorhanden.
# compose/.env ist gitignored - reale Werte landen nicht im Repository.

# PostgreSQL-Container (nur relevant wenn DB=postgres im Make-Aufruf).
# Passwort wird beim ersten `make stack-up DB=postgres` automatisch generiert,
# falls compose/.env auf dem Server noch nicht existiert.
POSTGRES_DB=varlens
POSTGRES_USER=varlens
POSTGRES_PASSWORD=REPLACE_WITH_GENERATED_PASSWORD

# Hostname/IP für Caddy-TLS-Zertifikat (Self-Signed aus interner CA).
# Wird beim Deploy in `make stack-up` automatisch auf die Server-IPv4 gesetzt.
# Manuell: hier eine Domain eintragen, dann Caddyfile auf Public-Block umstellen.
SERVER_HOST=REPLACE_WITH_SERVER_HOST
