{
  "name": "varlens",
  "version": "0.54.1",
  "description": "Offline variant analysis tool for external collaborators",
  "main": "./out/main/index.js",
  "author": "Bernt Popp <bernt.popp@gmail.com>",
  "license": "MIT",
  "scripts": {
    "predev": "npm run copy:molstar",
    "dev": "electron-vite dev",
    "copy:molstar": "node -e \"const fs=require('fs');const p=require('path');const s='node_modules/pdbe-molstar/build';const d='src/renderer/public';fs.copyFileSync(p.join(s,'pdbe-molstar-component.js'),p.join(d,'pdbe-molstar-component.js'));fs.copyFileSync(p.join(s,'pdbe-molstar-light.css'),p.join(d,'pdbe-molstar-light.css'))\"",
    "prebuild": "npm run copy:molstar",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "electron-vite build && electron-builder --publish onTag",
    "dist:win": "electron-vite build && electron-builder --win --publish onTag",
    "dist:mac": "electron-vite build && electron-builder --mac --publish onTag",
    "dist:linux": "electron-vite build && electron-builder --linux --publish onTag",
    "postinstall": "npx @electron/rebuild -f -w better-sqlite3-multiple-ciphers",
    "rebuild:electron": "npx @electron/rebuild -f -w better-sqlite3-multiple-ciphers",
    "rebuild:node": "npm rebuild better-sqlite3-multiple-ciphers",
    "lint": "eslint . --cache --cache-strategy content --concurrency=auto --fix",
    "lint:check": "eslint . --cache --cache-strategy content --concurrency=auto",
    "format": "prettier --cache --write .",
    "format:check": "prettier --cache --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "vue-tsc --noEmit -p tsconfig.renderer.json && tsc --noEmit -p tsconfig.node.json",
    "icons:generate": "png2icons resources/icon@2x.png build/icon -icns -ico && cp build/icon.ico resources/icon.ico",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:screenshots": "npx playwright test tests/e2e/screenshots.e2e.ts",
    "build:gene-ref": "npx tsx scripts/build-gene-reference-db.ts"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^10.0.1",
    "@mdi/js": "^7.4.47",
    "@playwright/test": "^1.59.1",
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/d3": "^7.4.3",
    "@types/file-saver": "^2.0.7",
    "@types/markdown-it": "^14.1.2",
    "@types/nock": "^11.1.0",
    "@types/node": "^25.5.2",
    "@types/plotly.js": "^3.0.10",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.2",
    "@vue/test-utils": "^2.4.6",
    "electron": "^40.8.5",
    "electron-builder": "^26.4.0",
    "electron-vite": "^5.0.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.7.0",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.9",
    "nock": "^14.0.10",
    "playwright": "^1.59.1",
    "png2icons": "^2.0.1",
    "prettier": "^3.8.1",
    "sass-embedded": "^1.99.0",
    "tar": "^7.5.13",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^7.3.2",
    "vite-plugin-vuetify": "^2.1.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.18",
    "vue": "^3.5.32",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
  },
  "build": {
    "appId": "com.varlens.app",
    "productName": "Varlens",
    "icon": "build/icon.png",
    "npmRebuild": false,
    "extraResources": [
      {
        "from": "resources/gene_reference.db",
        "to": "gene_reference.db"
      }
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3-multiple-ciphers/**/*",
      "out/renderer/pdbe-molstar-component.js"
    ],
    "files": [
      "out/**/*",
      "node_modules/better-sqlite3-multiple-ciphers/**/*"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "berntpopp",
      "repo": "varlens",
      "releaseType": "draft"
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable",
        "zip"
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.exe"
    },
    "linux": {
      "icon": "build/icons",
      "target": [
        "AppImage",
        "deb"
      ],
      "artifactName": "${productName}-${version}.${ext}",
      "category": "Science"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@vueuse/core": "^14.2.0",
    "adm-zip": "^0.5.17",
    "better-sqlite3-multiple-ciphers": "^12.8.0",
    "bottleneck": "^2.19.5",
    "d3": "^7.9.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "file-saver": "^2.0.5",
    "jstat": "^1.9.6",
    "kysely": "^0.28.15",
    "markdown-it": "^14.1.0",
    "nanoid": "^5.1.7",
    "pdbe-molstar": "^3.11.0",
    "pinia": "^3.0.4",
    "piscina": "^5.1.4",
    "plotly.js-basic-dist-min": "^3.5.0",
    "stream-json": "^2.1.0",
    "vue-router": "^5.0.4",
    "vuedraggable": "^4.1.0",
    "vuetify": "^4.0.5",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.3.6"
  },
  "overrides": {
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "@xmldom/xmldom": "^0.8.12",
    "lodash": "^4.18.1"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "none",
    "printWidth": 100,
    "endOfLine": "lf"
  }
}
