#!/usr/bin/env python3
"""
VarLens-IaC CLI.

Manages pilot and e2e environments through unified subcommands and
includes protective layers against accidental Teardown of the pilot
environment:

  - destructive actions (`down`) require typing the environment name
    literally
  - power actions (`stop`) require a y/N confirmation
  - `--yes` bypasses both layers in CI contexts

The e2e environment is built as a Disposable test: all destructive
actions run there without confirmation so that `varlens e2e run` can
clean up automatically.
"""
from __future__ import annotations

import argparse
import http.client
import os
import re
import shlex
import shutil
import subprocess
import sys
import time
import urllib.error
import urllib.request
from pathlib import Path

REPO = Path(__file__).resolve().parent.parent
ENVIRONMENTS = ("pilot", "e2e")


# ---------- helpers ----------

def env_dir(env: str) -> Path:
    return REPO / "tofu" / "environments" / env


def tfvars_path(env: str) -> Path:
    return env_dir(env) / "terraform.tfvars"


_TFVAR_LINE = re.compile(r'^\s*([A-Za-z_][A-Za-z0-9_]*)\s*=\s*"([^"]*)"\s*(?:#.*)?$')


def tfvars_get(env: str, key: str) -> str | None:
    f = tfvars_path(env)
    if not f.exists():
        return None
    for raw in f.read_text().splitlines():
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        m = _TFVAR_LINE.match(line)
        if m and m.group(1) == key:
            return m.group(2)
        # Fallback for unquoted values: strip trailing comment, then parse.
        if "=" in line and not m:
            head, _, _comment = line.partition("#")
            k, _, v = head.partition("=")
            if k.strip() == key:
                v = v.strip()
                if v.startswith('"') and v.endswith('"') and len(v) >= 2:
                    return v[1:-1]
                return v
    return None


def tofu(env: str, *args: str, capture: bool = False, check: bool = True) -> subprocess.CompletedProcess:
    cmd = ["tofu", f"-chdir={env_dir(env)}", *args]
    return subprocess.run(
        cmd,
        capture_output=capture,
        text=True,
        check=check,
    )


# Default: filter tofu's verbose `apply` / `destroy` output to keep only
# per-resource progress + summary; drop the full plan dump and per-attribute
# null-diff blocks that come before the operations. Bypass with --verbose
# (or VARLENS_VERBOSE=1) when you want the firehose for audit / debugging.
_TOFU_KEEP_RE = re.compile(
    r"^("
    r"(?:hcloud_|module\.|data\.)\S+: "
    r"(?:Creating|Creation complete|Still creating|Modifying|Modifications complete|Still modifying|"
    r"Destroying|Destruction complete|Still destroying|Reading|Read complete|Refreshing|Provisioning)"
    r"|Plan: \d"
    r"|Apply complete!|Destroy complete!"
    r"|Outputs:"
    r"|  [a-z_]+ +="          # output values, indented two spaces
    r"|Error:|Warning:"
    r")"
)


def _tofu_verbose() -> bool:
    return os.environ.get("VARLENS_VERBOSE") == "1" or os.environ.get("VARLENS_TOFU_VERBOSE") == "1"


def tofu_filtered(env: str, *args: str) -> None:
    """Run tofu with optional output filtering.

    --verbose / VARLENS_VERBOSE=1 / VARLENS_TOFU_VERBOSE=1 disable the
    filter and stream raw stdout/stderr. Otherwise only progress and
    summary lines pass through; the rest is suppressed.
    """
    if _tofu_verbose():
        tofu(env, *args)
        return
    cmd = ["tofu", f"-chdir={env_dir(env)}", *args]
    proc = subprocess.Popen(
        cmd, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True, bufsize=1
    )
    assert proc.stdout is not None
    for line in proc.stdout:
        if _TOFU_KEEP_RE.match(line):
            sys.stdout.write(line)
            sys.stdout.flush()
    rc = proc.wait()
    if rc != 0:
        fail(f"tofu {' '.join(args)} exited {rc} (re-run with --verbose for full output)")


def tofu_output(env: str, key: str) -> str | None:
    # Fast path: read the tfstate file directly. `tofu output -raw <key>`
    # can take seconds on some setups (state-lock contention, provider
    # plugin checks) which makes empty-state detection feel like a hang.
    # Reading the JSON state is sub-millisecond.
    import json
    tfstate = env_dir(env) / "terraform.tfstate"
    if tfstate.is_file():
        try:
            with tfstate.open() as f:
                data = json.load(f)
            outputs = data.get("outputs") or {}
            value = outputs.get(key, {}).get("value") if isinstance(outputs, dict) else None
            return str(value) if value not in (None, "") else None
        except (OSError, json.JSONDecodeError):
            pass  # fall through to tofu invocation

    # Fallback: invoke tofu. Same warning-on-stdout sentinel-sniff as
    # before to handle the empty-state case gracefully.
    proc = subprocess.run(
        ["tofu", f"-chdir={env_dir(env)}", "output", "-no-color", "-raw", key],
        capture_output=True, text=True,
    )
    if proc.returncode != 0:
        return None
    out = proc.stdout.strip()
    if not out or "No outputs found" in out or out.startswith("Warning:"):
        return None
    return out


def ipv4(env: str) -> str | None:
    return tofu_output(env, "ipv4")


def server_id(env: str) -> str | None:
    return tofu_output(env, "server_id")


def hcloud_token(env: str) -> str | None:
    return os.environ.get("HCLOUD_TOKEN") or tfvars_get(env, "hcloud_token")


def ssh_key_path() -> Path:
    return Path(os.environ.get("SSH_KEY", str(Path.home() / ".ssh" / "varlens-tofu"))).expanduser()


def e2e_ssh_key_path() -> Path:
    return Path.home() / ".ssh" / "varlens-e2e"


def need_init(env: str) -> bool:
    return not (env_dir(env) / ".terraform").exists()


def ensure_init(env: str) -> None:
    if need_init(env):
        log(f"[{env}] tofu init (one-time)")
        tofu(env, "init")


def ssh_run(
    ip: str,
    key: Path,
    command: str,
    *,
    connect_timeout: int = 15,
    total_timeout: int = 60,
    ephemeral_host: bool = False,
) -> subprocess.CompletedProcess:
    """ephemeral_host=True for e2e: Hetzner recycles IPs from a small pool,
    so the previous host key may collide — therefore no known_hosts lookup.

    connect_timeout bounds the initial TCP/SSH handshake; total_timeout
    caps overall command execution (including remote runtime) so that
    calling steps cannot hang indefinitely."""
    opts = ["-o", "BatchMode=yes", "-o", f"ConnectTimeout={connect_timeout}"]
    if ephemeral_host:
        opts += [
            "-o", "StrictHostKeyChecking=no",
            "-o", "UserKnownHostsFile=/dev/null",
            "-o", "LogLevel=ERROR",
        ]
    else:
        opts += ["-o", "StrictHostKeyChecking=accept-new"]
    try:
        return subprocess.run(
            ["ssh", "-i", str(key), *opts, f"deploy@{ip}", command],
            capture_output=True, text=True, timeout=total_timeout,
        )
    except subprocess.TimeoutExpired as exc:
        # Uniform handling: returncode=124 as with `timeout(1)`.
        return subprocess.CompletedProcess(
            args=exc.cmd,
            returncode=124,
            stdout=exc.stdout.decode() if isinstance(exc.stdout, bytes) else (exc.stdout or ""),
            stderr=(exc.stderr.decode() if isinstance(exc.stderr, bytes) else (exc.stderr or "")) + f"\n[varlens] ssh_run timeout after {total_timeout}s",
        )


def clear_host_key(ip: str) -> None:
    """Clean up any old host keys for a recycled IP."""
    subprocess.run(["ssh-keygen", "-R", ip], capture_output=True)


# ---------- output ----------

def log(msg: str) -> None:
    print(f"\033[36m[varlens]\033[0m {msg}", flush=True)


def fail(msg: str, code: int = 1) -> None:
    print(f"\033[31m[varlens]\033[0m {msg}", file=sys.stderr, flush=True)
    sys.exit(code)


# ---------- confirm ----------

def confirm_typed(word: str, yes: bool) -> None:
    if yes:
        log(f"--yes set, skipping typed confirmation for '{word}'")
        return
    print(f"\033[33mDestructive action. Type '{word}' literally to confirm, otherwise abort:\033[0m")
    try:
        got = input("> ").strip()
    except EOFError:
        got = ""
    if got != word:
        fail("Aborted.", code=2)


def confirm_yes(prompt: str, yes: bool) -> None:
    if yes:
        return
    try:
        got = input(f"{prompt} [y/N]: ").strip().lower()
    except EOFError:
        got = ""
    if got not in {"y", "yes", "j", "ja"}:
        fail("Aborted.", code=2)


# ---------- e2e bootstrap ----------

def ensure_e2e_ssh_key() -> str:
    """Dedicated keypair for e2e, different fingerprint than pilot."""
    priv = e2e_ssh_key_path()
    pub = Path(str(priv) + ".pub")
    if not priv.exists():
        log(f"Generating E2E SSH keypair {priv}")
        subprocess.run(
            ["ssh-keygen", "-t", "ed25519", "-f", str(priv), "-C", "varlens-e2e", "-N", ""],
            check=True,
        )
    return pub.read_text().strip()


def ensure_e2e_tfvars() -> None:
    f = tfvars_path("e2e")
    if f.exists():
        return
    pilot_token = tfvars_get("pilot", "hcloud_token")
    if not pilot_token:
        fail("No hcloud_token found in pilot/terraform.tfvars. E2E cannot bootstrap.")
    pub = ensure_e2e_ssh_key()
    body = (
        f'hcloud_token    = "{pilot_token}"\n'
        f'ssh_pubkey      = "{pub}"\n'
        f'ssh_pubkey_name = "varlens-e2e-tofu"\n'
    )
    # Token contains pilot Hetzner credentials — apply restrictive perms immediately on creation.
    fd = os.open(str(f), os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o600)
    with os.fdopen(fd, "w") as fh:
        fh.write(body)
    log(f"E2E tfvars written to {f} (mode 0600)")


# ---------- actions ----------

def action_plan(env: str, args) -> None:
    ensure_init(env)
    if env == "e2e":
        ensure_e2e_tfvars()
    tofu(env, "plan")


def action_up(env: str, args) -> None:
    ensure_init(env)
    if env == "e2e":
        ensure_e2e_tfvars()
    if getattr(args, "verbose", False):
        os.environ["VARLENS_VERBOSE"] = "1"
    tofu_filtered(env, "apply", "-auto-approve")


def action_down(env: str, args) -> None:
    # Empty-state short-circuit: if there is nothing in tofu state, the
    # confirmation prompt has nothing to defend against and `input()`
    # would softlock if a wrapper invoked us non-interactively. Skip
    # the prompt and exit cleanly. The previous behaviour would dump
    # tofu's "Plan: 0 to destroy" output regardless.
    if server_id(env) is None and ipv4(env) is None:
        log("No resources in local tofu state. Nothing to destroy.")
        return
    if env == "pilot":
        confirm_typed("pilot", args.yes)
    if getattr(args, "verbose", False):
        os.environ["VARLENS_VERBOSE"] = "1"
    tofu_filtered(env, "destroy", "-auto-approve")


def action_stop(env: str, args) -> None:
    if env == "pilot":
        confirm_yes("Stop pilot server?", args.yes)
    sid = server_id(env)
    tok = hcloud_token(env)
    if not sid or not tok:
        fail("No server state / token available.")
    _api_post(tok, f"/v1/servers/{sid}/actions/poweroff")
    log("Server stopped.")


def action_start(env: str, args) -> None:
    sid = server_id(env)
    tok = hcloud_token(env)
    if not sid or not tok:
        fail("No server state / token available.")
    _api_post(tok, f"/v1/servers/{sid}/actions/poweron")
    log("Server started.")


def _api_post(token: str, path: str) -> dict:
    import json
    import urllib.request
    req = urllib.request.Request(
        f"https://api.hetzner.cloud{path}",
        method="POST",
        headers={"Authorization": f"Bearer {token}"},
    )
    with urllib.request.urlopen(req, timeout=30) as r:
        return json.loads(r.read())


def action_status(env: str, args) -> None:
    import json
    import urllib.request
    sid = server_id(env)
    tok = hcloud_token(env)
    if not sid or not tok:
        log("No server present.")
        return
    req = urllib.request.Request(
        f"https://api.hetzner.cloud/v1/servers/{sid}",
        headers={"Authorization": f"Bearer {tok}"},
    )
    with urllib.request.urlopen(req, timeout=30) as r:
        s = json.loads(r.read())["server"]
    print(f"Name:     {s['name']}")
    print(f"Status:   {s['status']}")
    print(f"Type:     {s['server_type']['name']}")
    print(f"IPv4:     {s['public_net']['ipv4']['ip']}")
    print(f"Location: {s['datacenter']['location']['name']}")


def action_ssh(env: str, args) -> None:
    ip = ipv4(env)
    if not ip:
        fail("No server present.")
    key = e2e_ssh_key_path() if env == "e2e" else ssh_key_path()
    os.execvp("ssh", ["ssh", "-i", str(key), f"deploy@{ip}"])


def action_ip(env: str, args) -> None:
    ip = ipv4(env)
    if ip:
        print(ip)


def action_run(env: str, args) -> None:
    """Full E2E cycle: up -> stack-up -> setup-backup -> smoke -> restore-drill -> down."""
    if env != "e2e":
        fail("'run' is only intended for the e2e environment.")
    ensure_init(env)
    ensure_e2e_tfvars()

    if getattr(args, "verbose", False):
        os.environ["VARLENS_VERBOSE"] = "1"

    failed_step: str | None = None
    try:
        log("Step 1/6: tofu apply")
        tofu_filtered(env, "apply", "-auto-approve")

        ip = ipv4(env)
        if not ip:
            raise RuntimeError("No ipv4 output after apply.")
        log(f"Server IPv4: {ip}")

        # Hetzner recycles IPs from a pool; clear any old host keys.
        clear_host_key(ip)

        log("Step 2/6: waiting for cloud-init (may take 2-5 min)")
        _wait_for_cloud_init(ip, e2e_ssh_key_path())

        log("Step 3/6: stack-up")
        _stack_up(ip, e2e_ssh_key_path())

        backup_ran = False
        log("Step 4/6: setup-backup")
        backup_ran = _run_setup_backup(env, ip)

        log("Step 5/6: smoke")
        _smoke(ip, e2e_ssh_key_path())

        log("Step 6/6: restore-drill")
        _run_restore_drill(ip, expect_repo=backup_ran)

        log("E2E succeeded.")
    except Exception as exc:
        failed_step = f"{type(exc).__name__}: {exc}"
        log(f"E2E failed: {failed_step}")
    finally:
        if args.keep:
            log("--keep set, environment retained for inspection.")
        else:
            log("Cleaning up E2E environment (tofu destroy)")
            try:
                tofu_filtered(env, "destroy", "-auto-approve")
            except subprocess.CalledProcessError as exc:
                log(f"WARNING: tofu destroy failed: {exc}")
                log(f"Manual cleanup required: tofu -chdir={env_dir(env)} destroy")
                if not failed_step:
                    failed_step = "tofu destroy failed"

    if failed_step:
        fail(f"E2E run failed at step: {failed_step}")


def _wait_for_cloud_init(ip: str, key: Path, timeout: int = 900) -> None:
    """`cloud-init status --wait` blocks until bootstrap is complete.
    We poll via connect attempts because sshd only starts listening after a few seconds."""
    deadline = time.time() + timeout
    while time.time() < deadline:
        # ConnectTimeout=15 gives sshd time to come up; the actual --wait
        # may run up to 5 min on the session, hence the generous timeout.
        proc = ssh_run(
            ip, key,
            "cloud-init status --wait 2>&1 | tail -1",
            connect_timeout=15,
            total_timeout=30,
            ephemeral_host=True,
        )
        if proc.returncode == 0 and "done" in proc.stdout:
            log("cloud-init done.")
            return
        time.sleep(10)
    raise RuntimeError("cloud-init did not finish within the timeout")


def _stack_up(ip: str, key: Path) -> None:
    # rsync interprets -e as a shell string — spaces in the path would
    # break the parser, hence shlex.quote.
    ssh_cmd = (
        f"ssh -i {shlex.quote(str(key))} -o StrictHostKeyChecking=no "
        "-o UserKnownHostsFile=/dev/null -o LogLevel=ERROR"
    )
    subprocess.run(
        [
            "rsync", "-avz", "--delete",
            "-e", ssh_cmd,
            f"{REPO}/compose/",
            f"deploy@{ip}:/mnt/data/app/",
        ],
        check=True,
    )
    cmd = (
        "cd /mnt/data/app && "
        "if [ ! -f .env ]; then "
        "cp .env.example .env && "
        "sed -i \"s|REPLACE_WITH_GENERATED_PASSWORD|$(openssl rand -base64 32 | tr -d /+= | head -c 32)|\" .env; "
        "fi && "
        "docker compose pull && docker compose up -d"
    )
    proc = ssh_run(ip, key, cmd, connect_timeout=15, total_timeout=600, ephemeral_host=True)
    if proc.returncode == 124:
        raise RuntimeError("stack-up timeout (docker compose pull/up hanging)")
    if proc.returncode != 0:
        raise RuntimeError(f"stack-up failed: {proc.stderr}")


def _smoke(ip: str, key: Path) -> None:
    # Tuple shape: (label, expected, got, ok, tls_warn).
    # tls_warn signals an HTTPS probe that returned 0 (unreachable) — the
    # smoke run treats this as a soft warning rather than a hard failure
    # because the dominant cause is "Caddy hasn't issued a usable cert
    # yet" (LE rate limit on a recycled Hetzner IPv4, ACME still in flight,
    # self-signed fallback). Ports + bind-shape probes are unaffected.
    checks: list[tuple[str, object, object, bool, bool]] = []

    def check(label: str, expected, got):
        checks.append((label, expected, got, got == expected, False))

    def check_tls(label: str, expected, got):
        ok = got == expected
        tls_warn = (not ok) and got == 0
        checks.append((label, expected, got, ok, tls_warn))

    proc = ssh_run(ip, key, "echo yes", total_timeout=30, ephemeral_host=True)
    check("ssh", "yes", proc.stdout.strip())

    # HTTPS with self-signed cert: disable TLS verification (Concept Pilot intranet).
    import ssl
    insecure_ctx = ssl.create_default_context()
    insecure_ctx.check_hostname = False
    insecure_ctx.verify_mode = ssl.CERT_NONE

    # Check HTTP->HTTPS redirect without following the redirect (otherwise
    # self-signed TLS validation would obscure the actual status code).
    code = 0
    try:
        conn = http.client.HTTPConnection(ip, 80, timeout=10)
        try:
            conn.request("GET", "/")
            resp = conn.getresponse()
            code = resp.status
        finally:
            conn.close()
    except Exception:
        code = 0
    check("http->https redirect", 308, code)

    for path, expected in [("/", 200), ("/monitor/", 401), ("/logs/", 401), ("/varlens/healthz", 200)]:
        try:
            req = urllib.request.Request(f"https://{ip}{path}")
            with urllib.request.urlopen(req, timeout=10, context=insecure_ctx) as r:
                code = r.status
        except urllib.error.HTTPError as exc:
            code = exc.code
        except Exception:
            code = 0
        check_tls(f"https {path}", expected, code)

    # F5: structural bind-shape probes. The previous "direct port closed"
    # checks treated curl rc=000 as "ok closed", but rc=000 also covers
    # connect-refused, timeout, dropped packet, route-unreachable. Replace
    # with a positive assertion that the listener is bound to loopback
    # only, which is the actual security property we care about.
    for port, label in ((3001, "Kuma bound to localhost only"),
                        (8080, "Dozzle bound to localhost only")):
        cmd = (
            f"ss -tlnp 2>/dev/null | "
            f"grep -qE '(127\\.0\\.0\\.1|\\[::1\\]):{port}\\b' "
            f"&& echo yes || echo no"
        )
        proc = ssh_run(ip, key, cmd, total_timeout=30, ephemeral_host=True)
        check(label, "yes", proc.stdout.strip())

    proc = ssh_run(
        ip, key,
        "cd /mnt/data/app && docker compose ps --status running --services | grep -cE '^(caddy|uptime-kuma|dozzle|varlens|postgres)$'",
        total_timeout=30,
        ephemeral_host=True,
    )
    check("running services", "5", proc.stdout.strip())

    for label, expected, got, ok, tls_warn in checks:
        if ok:
            marker = "ok  "
        elif tls_warn:
            marker = "WARN"
        else:
            marker = "FAIL"
        print(f"  {marker} {label}: expected {expected!r}, got {got!r}")
    hard_failed = [c for c in checks if not c[3] and not c[4]]
    tls_warned = [c for c in checks if c[4]]
    if hard_failed:
        raise RuntimeError(f"{len(hard_failed)} smoke check(s) failed")
    if tls_warned:
        print(f"  ({len(tls_warned)} HTTPS probe(s) WARNed — TLS not ready; "
              f"check `docker compose logs caddy` if cert state is unexpected)")


def _run_setup_backup(env: str, ip: str) -> bool:
    """Returns True if a backup was actually configured."""
    e = os.environ.copy()
    e["SERVER_IP"] = ip
    e["SSH_KEY"] = str(e2e_ssh_key_path())
    e["HCLOUD_TOKEN"] = hcloud_token(env) or ""
    # Bucket name unique per E2E run so tests do not overwrite the pilot backup.
    # setup-backup.py reads BUCKET_NAME, not BUCKET.
    e["BUCKET_NAME"] = f"varlens-e2e-{int(time.time())}"
    if not (e.get("RESTIC_S3_ACCESS_KEY") and e.get("RESTIC_S3_SECRET_KEY")):
        log("WARNING: RESTIC_S3_ACCESS_KEY/SECRET not set — skipping backup in E2E.")
        return False
    # E2E is always greenfield: fresh server, fresh bucket per run.
    # --force suppresses the preflight guard that would otherwise trigger
    # when reusing an existing bucket name.
    subprocess.run(
        [str(REPO / "scripts" / "setup-backup.py"), "--force"],
        env=e, check=True,
    )
    return True


def _run_restore_drill(ip: str, *, expect_repo: bool) -> None:
    e = os.environ.copy()
    e["IP"] = ip
    e["SSH_KEY"] = str(e2e_ssh_key_path())
    e["PROTOCOL_FILE"] = str(REPO / ".internalplanning" / "restore-log-e2e.md")
    e["SSH_STRICT"] = "no"
    proc = subprocess.run([str(REPO / "scripts" / "restore-drill.sh")], env=e)
    if proc.returncode != 0:
        if expect_repo:
            raise RuntimeError("Restore drill failed despite configured backup")
        log("Restore drill did not run through (no backup configured — acceptable in E2E without S3 creds).")


# ---------- main ----------

def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="varlens",
        description="VarLens-IaC CLI: unified control of the pilot and e2e environments.",
    )
    sub = p.add_subparsers(dest="env", required=True)

    def add_action(actions, name, func, help_=None):
        ap = actions.add_parser(name, help=help_)
        ap.add_argument("--yes", action="store_true", help="Skip confirmation prompts (for CI)")
        ap.add_argument(
            "--verbose",
            action="store_true",
            help="Show raw tofu output (default: filter to per-resource progress + summary)",
        )
        ap.set_defaults(func=func)
        return ap

    for env in ENVIRONMENTS:
        ep = sub.add_parser(env, help=f"Control the {env} environment")
        # `--yes` is only defined at the action level (see add_action). If it
        # were also at the env level, the action default would reset it to
        # False during parsing — so we deliberately omit it here.
        actions = ep.add_subparsers(dest="action", required=True)

        add_action(actions, "plan", action_plan)
        add_action(actions, "up", action_up)
        add_action(actions, "down", action_down)
        add_action(actions, "stop", action_stop)
        add_action(actions, "start", action_start)
        add_action(actions, "status", action_status)
        add_action(actions, "ssh", action_ssh)
        add_action(actions, "ip", action_ip)

        if env == "e2e":
            run = add_action(actions, "run", action_run, "Full-cycle E2E test with automatic cleanup")
            run.add_argument("--keep", action="store_true", help="Do not destroy environment after run")

    return p


def main(argv: list[str] | None = None) -> None:
    args = build_parser().parse_args(argv)
    args.func(args.env, args)


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        fail("Aborted (Ctrl-C).", code=130)
    except subprocess.CalledProcessError as exc:
        fail(f"Subprocess failed: {exc}", code=exc.returncode or 1)
