.DS_Store

# OpenTofu / Terraform
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example

# Secrets
*.age
*.key
!*.pub
.env
.env.*
!.env.example

# SOPS
.sops.yaml.bak

# SOPS-encrypted secret material. Even though SOPS encrypts the values,
# the file metadata (key names, recipient pubkeys, AES ciphertext) is
# regenerated on every setup-backup / setup-monitoring run and lives
# alongside the operator's age key locally. Don't commit it for the
# private fork. The age public key in .sops.yaml is enough for the
# encryption side; decryption needs the private key which never moves.
secrets/*.yaml
!secrets/example.yaml

# Editor
.idea/
.vscode/
*.swp

# Internal planning documents (German source-of-truth for Confluence mirror).
# Kept locally for stakeholder reference and AI context, never committed.
.internalplanning/
