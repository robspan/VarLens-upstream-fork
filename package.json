{
  "name": "varlens",
  "version": "0.9.2",
  "description": "Offline variant analysis tool for external collaborators",
  "main": "./out/main/index.js",
  "author": "Bernt Popp <bernt.popp@gmail.com>",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "electron-vite build && electron-builder --publish onTag",
    "dist:win": "electron-vite build && electron-builder --win --publish onTag",
    "dist:mac": "electron-vite build && electron-builder --mac --publish onTag",
    "dist:linux": "electron-vite build && electron-builder --linux --publish onTag",
    "postinstall": "npx @electron/rebuild -f -w better-sqlite3-multiple-ciphers",
    "rebuild:electron": "npx @electron/rebuild -f -w better-sqlite3-multiple-ciphers",
    "rebuild:node": "npm rebuild better-sqlite3-multiple-ciphers",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "vue-tsc --noEmit -p tsconfig.renderer.json && tsc --noEmit -p tsconfig.node.json",
    "icons:generate": "png2icons resources/icon@2x.png build/icon -icns -ico && cp build/icon.ico resources/icon.ico"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@electron/rebuild": "^4.0.3",
    "@mdi/font": "^7.4.47",
    "@types/adm-zip": "^0.5.7",
    "@types/better-sqlite3": "^7.6.13",
    "@types/file-saver": "^2.0.7",
    "@types/markdown-it": "^14.1.2",
    "@types/nock": "^11.1.0",
    "@types/node": "^25.2.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "electron": "^40.2.1",
    "electron-builder": "^26.4.0",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.7.0",
    "happy-dom": "^20.5.0",
    "nock": "^14.0.10",
    "png2icons": "^2.0.1",
    "prettier": "^3.8.1",
    "sass-embedded": "^1.97.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.0.18",
    "vue": "^3.5.27",
    "vue-tsc": "^3.2.4"
  },
  "build": {
    "appId": "com.varlens.app",
    "productName": "Varlens",
    "icon": "build/icon.png",
    "npmRebuild": false,
    "asarUnpack": [
      "node_modules/better-sqlite3-multiple-ciphers/**/*"
    ],
    "files": [
      "out/**/*",
      "node_modules/better-sqlite3-multiple-ciphers/**/*"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "berntpopp",
      "repo": "varlens",
      "releaseType": "draft"
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable",
        "zip"
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.exe"
    },
    "linux": {
      "icon": "build/icons",
      "target": [
        "AppImage",
        "deb"
      ],
      "artifactName": "${productName}-${version}.${ext}",
      "category": "Science"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@vueuse/core": "^14.2.0",
    "adm-zip": "^0.5.16",
    "better-sqlite3-multiple-ciphers": "^12.6.2",
    "bottleneck": "^2.19.5",
    "electron-log": "^5.4.3",
    "file-saver": "^2.0.5",
    "markdown-it": "^14.1.0",
    "pinia": "^3.0.4",
    "stream-json": "^1.9.1",
    "vuedraggable": "^4.1.0",
    "vuetify": "^3.11.8",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.3.6"
  },
  "overrides": {
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "none",
    "printWidth": 100,
    "endOfLine": "lf"
  }
}
