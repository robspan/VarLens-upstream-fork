# Environment values for the Compose stack.
# Loaded automatically by Docker Compose when present as compose/.env.
# compose/.env is gitignored - real values do not end up in the repository.

# PostgreSQL container (only relevant when DB=postgres in the make invocation).
# The password is generated automatically on the first `make stack-up DB=postgres`
# if compose/.env does not yet exist on the server. The generated value is
# persisted server-side at /etc/varlens/postgres-password (root:root, 0600) so
# that subsequent .env regenerations (e.g. after rsync or manual edits) reuse
# the same password instead of rotating it. To rotate intentionally, delete
# both /mnt/data/app/.env and /etc/varlens/postgres-password before re-running
# `make stack-up DB=postgres`.
POSTGRES_DB=varlens
POSTGRES_USER=varlens
POSTGRES_PASSWORD=REPLACE_WITH_GENERATED_PASSWORD

# Hostname/IP for the Caddy TLS certificate.
# Set automatically to the server's IPv4 at deploy time by `make stack-up`.
# Override: set this to a real domain (DNS A-record pointing here) to use
# Let's Encrypt instead of a self-signed certificate.
SERVER_HOST=REPLACE_WITH_SERVER_HOST

# TLS profile snippet name (defined in compose/Caddyfile):
#   tls-internal    self-signed (no internet, browser warning)
#   tls-le-classic  Let's Encrypt 90-day cert (requires SERVER_HOST = real domain)
#   tls-le-ip       Let's Encrypt 7-day shortlived cert for raw public IP
# Auto-set by `make stack-up`:
#   default                          -> tls-le-ip   (raw IP, public CA)
#   make stack-up DOMAIN=foo.de      -> tls-le-classic
#   make stack-up TLS=internal       -> tls-internal
CADDY_TLS_PROFILE=tls-le-ip

# --- VarLens application container ---------------------------------------
#
# Image reference. Use the `:edge` floating tag for first boot (auto-pulls
# whatever was last published) and switch to a digest pin
# (ghcr.io/robspan/varlens-web@sha256:...) once you've decided on a known-
# good build. Each successful publish-web workflow run prints the digest
# in its summary.
VARLENS_IMAGE=ghcr.io/robspan/varlens-web:edge

# Internal config — leave defaults unless you know what you're doing.
VARLENS_DB_PATH=/data/varlens.db
VARLENS_WEB_PORT=8080
VARLENS_LOG_LEVEL=info

# One-shot admin bootstrap (optional). If ALL THREE are set on FIRST boot
# and no admin exists yet, the app creates an Argon2 admin and writes the
# recovery key to /mnt/data/app/admin-recovery-key.txt (mode 0600). After
# capturing the recovery key from that file, delete the file AND unset
# these three lines so the plaintext password does not linger in the
# container's environment after bootstrap.
VARLENS_ADMIN_USERNAME=
VARLENS_ADMIN_PASSWORD=
VARLENS_ADMIN_DISPLAY_NAME=
