# VarLens — web mode environment
#
# Only used when running the Fastify web build (`out/web/server.cjs` or the
# container image). Desktop builds ignore this file entirely. Copy to
# `.env.web` and fill in for local runs; in production the operator sets
# these via the Compose stack (see VarLens-IaC `compose/.env`).

# --- Server ---------------------------------------------------------------

# Bind port. The image's EXPOSE and HEALTHCHECK are pinned to 8080 — do not
# override this inside the container; remap externally via Compose `ports:`
# or Caddy upstream config instead.
VARLENS_WEB_PORT=8080

# Pino log level: trace | debug | info | warn | error | fatal
VARLENS_LOG_LEVEL=info

# --- Storage --------------------------------------------------------------

# REQUIRED. SQLite file path. The container default points at the persistent
# volume mount (/data/varlens.db). The server refuses to start if this is
# unset or empty — silently demoting to an in-memory DB on a misconfigured
# deployment would lose data on every restart.
#
# Stage 1 is SQLite-only per IaC `DB ?= sqlite` default and §bewertung2;
# Postgres support is Stage 1.5.
VARLENS_DB_PATH=/data/varlens.db

# --- Admin bootstrap (optional, one-shot) --------------------------------
#
# If all three are set on FIRST boot, the server creates an Argon2 admin
# account using the existing AuthService.createFirstUser() function. On
# subsequent boots this is a no-op (existing admin is left alone — the
# password env value is never reused).
#
# IMPORTANT: on creation, a one-time recovery key is written to
#   <dirname VARLENS_DB_PATH>/admin-recovery-key.txt   (mode 0600)
# alongside the SQLite file. The container logs emit a WARN line that
# names the path but never contains the key itself, so log aggregators
# (Loki, journald, CloudWatch, ...) do not retain the secret. The
# operator must capture the file's contents on first boot and DELETE
# the file. The key cannot be regenerated; if you lose it, the admin
# account cannot be recovered.
#
# After the first successful boot, remove these three values from your
# environment so the password and recovery key do not linger in
# /proc/<pid>/environ or `docker inspect` output.
#
# If left empty, no admin is created — the operator handles bootstrap
# manually via the UI on first visit.

VARLENS_ADMIN_USERNAME=
VARLENS_ADMIN_PASSWORD=
VARLENS_ADMIN_DISPLAY_NAME=
